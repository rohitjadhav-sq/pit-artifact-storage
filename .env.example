# HTTP
PORT=3000
HOST=0.0.0.0

# Blob storage root (in docker-compose this is a named volume mount)
STORAGE_ROOT=/data/artifacts

# Maximum accepted artifact size in bytes (default 100 MiB)
MAX_UPLOAD_BYTES=104857600

# PostgreSQL connection string (metadata store)
DATABASE_URL=postgres://pit:pit@db:5432/pit

# Comma-separated list of browser origins allowed by CORS
CORS_ORIGINS=http://localhost:5173

# Interval for SSE keep-alive comments (milliseconds)
SSE_KEEPALIVE_MS=20000

# pino log level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info
