#!/bin/sh
# Pre-commit gate: formatting, lint, types, tests. All four are fast (<10s total).
# Wired up automatically by `npm install` (the "prepare" script sets core.hooksPath).
# Bypass in an emergency with `git commit --no-verify` but fix it before hand-in.
set -e

echo "pre-commit: prettier check"
npm run --silent format:check

echo "pre-commit: eslint"
npm run --silent lint

echo "pre-commit: typecheck"
npm run --silent typecheck

echo "pre-commit: tests"
npm run --silent test

echo "pre-commit: all checks passed"
